import streamlit as st
from deep_translator import GoogleTranslator
from pypinyin import pinyin, Style
from gtts import gTTS
import io

# 페이지 설정
st.set_page_config(page_title="한-중 번역 & 발음기", page_icon="🇨🇳", layout="centered")

st.title("🇨🇳 한-중 번역 및 발음기")
st.markdown("한국어를 입력하면 **중국어(간체)** 번역과 함께 **병음(발음 기호)** 및 **원어민 음성**을 제공합니다.")

# 텍스트 입력 창
text_to_translate = st.text_area("번역할 한국어를 입력하세요:", height=150, placeholder="안녕하세요, 반갑습니다!")

# 번역 버튼
if st.button("번역 및 발음 듣기", type="primary"):
    if text_to_translate.strip() == "":
        st.warning("번역할 텍스트를 먼저 입력해주세요!")
    else:
        with st.spinner("번역 및 음성 생성 중입니다..."):
            try:
                # 1. 중국어 번역 (간체)
                zh_text = GoogleTranslator(source='ko', target='zh-CN').translate(text_to_translate)
                
                # 2. 병음(발음 기호) 추출
                # pinyin()은 리스트의 리스트 형태를 반환하므로 하나의 문자열로 합쳐줍니다.
                pinyin_list = pinyin(zh_text, style=Style.TONE)
                pinyin_text = " ".join([item[0] for item in pinyin_list])
                
                # 3. 음성(TTS) 오디오 파일 생성
                tts = gTTS(text=zh_text, lang='zh-CN')
                audio_buffer = io.BytesIO()
                tts.write_to_fp(audio_buffer)
                audio_bytes = audio_buffer.getvalue()

                st.success("완료되었습니다!")
                
                # 결과 출력 화면 배치
                st.subheader("🇨🇳 중국어 번역 결과")
                st.info(zh_text)
                
                st.subheader("🔤 발음 기호 (병음)")
                st.success(pinyin_text)
                
                st.subheader("🎧 원어민 발음 듣기")
                st.audio(audio_bytes, format='audio/mp3')

            except Exception as e:
                st.error(f"오류가 발생했습니다. 다시 시도해주세요. (에러 내용: {e})")
